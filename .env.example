# RECALL AI — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit the actual .env file.

# -------------------------------------------------------
# Django Core
# -------------------------------------------------------
# Generate a new one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=your-secret-key-here-minimum-50-chars

# Set to False in production
DEBUG=True

# Comma-separated. Example: 127.0.0.1,localhost,yourdomain.com
ALLOWED_HOSTS=127.0.0.1,localhost

# -------------------------------------------------------
# Database (MySQL)
# -------------------------------------------------------
DB_NAME=recallai_db
DB_USER=root
DB_PASSWORD=your-database-password-here
DB_HOST=127.0.0.1
DB_PORT=3306

# -------------------------------------------------------
# AI / External APIs
# -------------------------------------------------------
# Get your free key at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here

# -------------------------------------------------------
# Optional: System paths (only needed if not in PATH)
# -------------------------------------------------------
# POPPLER_PATH=C:/Program Files/poppler/bin
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
