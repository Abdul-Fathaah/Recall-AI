.env
.env.local
.env.production
.env.staging
*.env

# ============================================================
# PYTHON & DJANGO
# ============================================================
*.pyc
*.pyo
*.pyd
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/
ENV/

# Django
db.sqlite3
db.sqlite3-journal
*.log
local_settings.py

# Migrations (optional — comment out if you want to commit migrations)
